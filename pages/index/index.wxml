<view class="container">
  <!-- ======== 顶部 Header ======== -->
  <view class="header">
    <view class="header-title-row">
      <view class="title-wrapper">
        <image class="header-logo" src="/images/chinatelcom.png" mode="aspectFit"></image>
        <text class="title">LLM Tokens Market</text>
        <image class="header-logo-right" src="/images/upload-icon.png" mode="aspectFit"></image>
      </view>
    </view>
    <text class="subtitle" wx:if="{{activeTab === 'tokens'}}">单位：元/百万tokens</text>

    <!-- Tokens Tab 内容 -->
    <block wx:if="{{activeTab === 'tokens'}}">
      <view class="source-row">
        <view class="source-item {{activeSource === 'selfhosted' ? 'active' : ''}} {{selfhosted.connected ? '' : 'disabled'}}" bindtap="onSwitchSource" data-source="selfhosted">
          <text class="source-icon">{{selfhosted.icon}}</text>
          <text class="source-name">主数据源</text>
          <text class="source-time {{selfhosted.color}}">{{selfhosted.updateTime || '连接中...'}}</text>
        </view>
        <view class="source-divider"></view>
        <view class="source-item {{activeSource === 'cloud' ? 'active' : ''}} {{cloud.connected ? '' : 'disabled'}}" bindtap="onSwitchSource" data-source="cloud">
          <text class="source-icon">{{cloud.icon}}</text>
          <text class="source-name">备份源</text>
          <text class="source-time {{cloud.color}}">{{cloud.updateTime || '连接中...'}}</text>
        </view>
      </view>
      <scroll-view class="provider-tags" scroll-x="true" enable-flex="true" wx:if="{{!loading && providerTags.length > 0}}">
        <view class="provider-tag-item {{item.active ? 'active' : ''}}" wx:for="{{providerTags}}" wx:key="name" bindtap="onProviderTag" data-name="{{item.name}}">
          <text>{{item.name}}</text>
        </view>
      </scroll-view>
    </block>

    <block wx:if="{{activeTab === 'compute'}}">
      <view class="compute-meta" wx:if="{{!computeLoading && computeData.length > 0}}">
        <text class="compute-summary">共 {{computeFilteredList.length}} 规格 | 可售 {{computeAvailable}} | 售罄 {{computeSellout}} | 🕐 {{computeUpdateTime || ''}}</text>
      </view>
    </block>
  </view>

  <!-- ======== 内容区（留出底部tab空间） ======== -->
  <view class="content-area">

    <!-- Tokens 加载 -->
    <view class="loading-bar" wx:if="{{loading && activeTab === 'tokens'}}">
      <text class="loading-text">正在获取最新价格数据...</text>
    </view>
    <view class="loading-bar" wx:if="{{computeLoading && activeTab === 'compute'}}">
      <text class="loading-text">正在获取算力数据...</text>
    </view>

    <!-- Tokens 筛选 -->
    <block wx:if="{{activeTab === 'tokens' && !loading}}">
      <view class="filter-bar">
        <input class="search-input" placeholder="搜索模型名称..." value="{{keyword}}" bindinput="onSearch" placeholder-class="search-placeholder"/>
      </view>
      <view class="sort-bar">
        <view class="sort-item {{sortBy === 'input' ? 'active' : ''}}" bindtap="onSort" data-field="input">输入价格 ▾</view>
        <view class="sort-item {{sortBy === 'output' ? 'active' : ''}}" bindtap="onSort" data-field="output">输出价格 ▾</view>
        <view class="sort-item {{sortBy === 'name' ? 'active' : ''}}" bindtap="onSort" data-field="name">名称</view>
      </view>
    </block>

    <!-- 算力筛选：区域 + GPU型号 -->
    <block wx:if="{{activeTab === 'compute' && !computeLoading}}">
      <view class="compute-filter-row" wx:if="{{computeRegionOptions.length > 1}}">
        <view class="compute-filter-half">
          <picker mode="selector" range="{{computeRegionOptions}}" value="{{computeRegionIndex}}" bindchange="onComputeRegionChange">
            <view class="picker-display">
              <text class="picker-label">区域</text>
              <text>{{computeRegionOptions[computeRegionIndex]}}</text>
              <text class="picker-arrow">▾</text>
            </view>
          </picker>
        </view>
        <view class="compute-filter-half">
          <picker mode="selector" range="{{computeGpuOptions}}" value="{{computeGpuIndex}}" bindchange="onComputeGpuChange">
            <view class="picker-display">
              <text class="picker-label">GPU</text>
              <text>{{computeGpuOptions[computeGpuIndex]}}</text>
              <text class="picker-arrow">▾</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="sellout-checking" wx:if="{{computeCheckingSellout}}">
        <text>正在检查库存状态...</text>
      </view>
    </block>

    <!-- Tokens 列表：按量 + 订阅混合 -->
    <view class="price-list" wx:if="{{activeTab === 'tokens' && !loading}}">
      <block wx:for="{{filteredList}}" wx:key="id">
        <!-- 按量计费卡片 -->
        <view class="price-card" wx:if="{{!item.planType}}" bindtap="onTapModel" data-id="{{item.id}}">
          <view class="card-header">
            <view class="provider-tag" style="background:{{item.providerColor}}">{{item.provider}}</view>
            <view class="model-badges">
              <text class="badge badge-new" wx:if="{{item.isNew}}">NEW</text>
              <text class="badge badge-hot" wx:if="{{item.isHot}}">HOT</text>
            </view>
          </view>
          <view class="model-name">{{item.name}}<text class="stale-icon" wx:if="{{item.stale}}"> ⚠️</text></view>
          <view class="model-tag-row" wx:if="{{item.tag}}"><text class="model-tag">{{item.tag}}</text></view>
          <view class="model-desc" wx:if="{{item.desc}}">{{item.desc}}</view>
          <view class="price-row">
            <view class="price-item">
              <text class="price-label">输入</text>
              <text class="price-value">{{item.currency || "¥"}}{{item.inputPrice}}</text>
              <text class="price-note" wx:if="{{item.inputNote}}">{{item.inputNote}}</text>
            </view>
            <view class="price-divider"></view>
            <view class="price-item">
              <text class="price-label">输出</text>
              <text class="price-value">{{item.currency || "¥"}}{{item.outputPrice}}</text>
              <text class="price-note" wx:if="{{item.outputNote}}">{{item.outputNote}}</text>
            </view>
          </view>
          <view class="cache-row" wx:if="{{item.cachePrice}}">
            <text class="cache-label">缓存命中:</text><text class="cache-value">{{item.currency || "¥"}}{{item.cachePrice}}</text>
          </view>
          <view class="context-info" wx:if="{{item.contextWindow}}">上下文: {{item.contextWindow}}</view>
        </view>
        <!-- 订阅套餐卡片（多档位） -->
        <view class="plan-card" wx:elif="{{item.planType && item.planTiers && item.planTiers.length > 0}}" bindtap="onTapModel" data-id="{{item.id}}">
          <view class="card-header">
            <view class="provider-tag" style="background:{{item.providerColor}}">{{item.provider}}</view>
            <view class="plan-badge">📦 订阅</view>
          </view>
          <view class="model-name">{{item.name}}</view>
          <view class="model-desc" wx:if="{{item.desc}}">{{item.desc}}</view>
          <view class="plan-tiers">
            <view class="plan-tier {{tier.f ? 'featured' : ''}}" wx:for="{{item.planTiers}}" wx:key="n" wx:for-item="tier">
              <view class="plan-tier-name">{{tier.n}}</view>
              <view class="plan-tier-price">¥{{tier.pr}}<text class="plan-tier-period">/{{tier.pe}}</text></view>
              <view class="plan-tier-desc" wx:if="{{tier.d}}">{{tier.d}}</view>
            </view>
          </view>
        </view>
        <!-- 订阅套餐卡片（单档位） -->
        <view class="plan-single" wx:elif="{{item.planType}}" bindtap="onTapModel" data-id="{{item.id}}">
          <view class="card-header">
            <view class="provider-tag" style="background:{{item.providerColor}}">{{item.provider}}</view>
            <view class="plan-badge">📦 订阅</view>
          </view>
          <view class="model-name">{{item.name}}</view>
          <view class="model-desc" wx:if="{{item.desc}}">{{item.desc}}</view>
          <view class="plan-single-price" wx:if="{{item.planPrice > 0}}">¥{{item.planPrice}}<text class="plan-price-period">/{{item.planPeriod}}</text></view>
          <view class="plan-single-meta" wx:if="{{item.planTags && item.planTags.length > 0}}">
            <text class="plan-single-tag" wx:for="{{item.planTags}}" wx:key="*this" wx:for-item="tg">{{tg}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 算力列表 -->
    <view class="compute-list" wx:if="{{activeTab === 'compute' && !computeLoading}}">
      <view class="compute-card {{item.sellout ? 'sellout' : ''}}" wx:for="{{computeFilteredList}}" wx:key="_key">
        <view class="compute-card-header">
          <view class="compute-badge {{item.sellout ? 'sold' : 'available'}}">{{item.sellout ? '售罄' : '可售'}}</view>
          <view class="compute-region-tag">{{item.region}}</view>
          <view class="compute-gpu-tag">{{item.gpuModel}}</view>
        </view>
        <view class="compute-spec-name">{{item.spec}}</view>
        <view class="compute-flavor" wx:if="{{item.flavorName}}">{{item.flavorName}}</view>
        <view class="compute-specs">
          <view class="compute-spec-item"><text class="cs-label">vCPU</text><text class="cs-value">{{item.vCPU}}</text></view>
          <view class="compute-spec-item"><text class="cs-label">内存</text><text class="cs-value">{{item.memGB}}G</text></view>
          <view class="compute-spec-item"><text class="cs-label">显存</text><text class="cs-value">{{item.vramGB}}GB</text></view>
          <view class="compute-spec-item" wx:if="{{!item.sellout && item.ecsAvail > 0}}"><text class="cs-label">可售</text><text class="cs-value">{{item.ecsAvail}}台</text></view>
        <view class="compute-spec-item" wx:if="{{item.ctLimit}}"><text class="cs-label">限额</text><text class="cs-value">{{item.ctLimit}}</text></view>
        </view>
        <view class="compute-extra">
          <text class="compute-az" wx:if="{{item.az && item.az.length > 0}}">可用区: {{item.az}}</text>
          <text class="compute-bw" wx:if="{{item.bwMax > 0}}">带宽: {{item.bwBase}}-{{item.bwMax}}Gbps</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{activeTab === 'tokens' && !loading && filteredList.length === 0}}">
      <text class="empty-icon">🔍</text><text class="empty-text">未找到匹配的模型</text>
    </view>
    <view class="empty-state" wx:if="{{activeTab === 'compute' && !computeLoading && computeFilteredList.length === 0}}">
      <text class="empty-icon">🖥️</text><text class="empty-text">暂无算力数据</text>
    </view>

    <!-- Footer -->
    <view class="footer-note" wx:if="{{!loading && !computeLoading}}">
      <text wx:if="{{activeTab === 'tokens'}}">数据来源：DeepSeek · 天翼云 · 阿里百炼 · 硅基流动 · 智谱 · 中国联通</text>
      <text wx:if="{{activeTab === 'compute'}}">数据来源：天翼云 OpenAPI · 华东及江苏区域</text>
      <text class="footer-disclaimer">价格可能变动，请以官方最新公告为准</text>
    </view>
  </view>

  <!-- ======== 底部 Tab 栏（浏览器标签页风格） ======== -->
  <view class="bottom-tabs">
    <view class="bottom-tab-item {{activeTab === 'tokens' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="tokens">
      <text class="bottom-tab-icon">🔑</text>
      <text class="bottom-tab-label">Tokens</text>
      <view class="bottom-tab-indicator" wx:if="{{activeTab === 'tokens'}}"></view>
    </view>
    <view class="bottom-tab-item {{activeTab === 'compute' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="compute">
      <text class="bottom-tab-icon">⚡</text>
      <text class="bottom-tab-label">算力</text>
      <view class="bottom-tab-indicator" wx:if="{{activeTab === 'compute'}}"></view>
    </view>
  </view>
</view>
