<view class="container">
  <view class="detail-card">
    <view class="model-header">
      <view class="provider-tag" style="background:{{model.providerColor}}">{{model.provider}}</view>
      <view class="header-name">{{model.name}}</view>
      <text class="header-desc" wx:if="{{model.desc}}">{{model.desc}}</text>
      <view class="header-tag" wx:if="{{model.tag}}">
        <text class="model-tag-detail">{{model.tag}}</text>
      </view>
    </view>
    <!-- 按量计费价格 -->
    <view class="section" wx:if="{{!model.planType}}">
      <text class="section-title">💰 价格详情 (元/百万tokens)</text>
      <view class="price-table">
        <view class="price-row-detail"><text class="price-type">输入价格</text><text class="price-num">{{model.currency || "¥"}}{{model.inputPrice}}</text></view>
        <view class="price-row-detail" wx:if="{{model.inputNote}}"><text class="price-type">输入说明</text><text class="price-num small">{{model.inputNote}}</text></view>
        <view class="price-row-detail"><text class="price-type">输出价格</text><text class="price-num">{{model.currency || "¥"}}{{model.outputPrice}}</text></view>
        <view class="price-row-detail" wx:if="{{model.outputNote}}"><text class="price-type">输出说明</text><text class="price-num small">{{model.outputNote}}</text></view>
        <view class="price-row-detail" wx:if="{{model.cachePrice}}"><text class="price-type">缓存命中</text><text class="price-num">{{model.currency || "¥"}}{{model.cachePrice}}</text></view>
      </view>
    </view>
    <!-- 订阅套餐详情 -->
    <view class="section" wx:if="{{model.planType}}">
      <text class="section-title">📦 订阅套餐</text>
      <!-- 多档位 -->
      <view class="detail-tiers" wx:if="{{model.tiers && model.tiers.length > 0}}">
        <view class="detail-tier {{tier.featured ? 'featured' : ''}}" wx:for="{{model.tiers}}" wx:key="n" wx:for-item="tier">
          <view class="detail-tier-header">
            <text class="detail-tier-name">{{tier.name}}</text>
            <text class="detail-tier-badge" wx:if="{{tier.featured}}">推荐</text>
          </view>
          <text class="detail-tier-price">{{model.currency || "¥"}}{{tier.price}}<text class="detail-tier-period">/{{tier.period}}</text></text>
          <text class="detail-tier-desc" wx:if="{{tier.desc}}">{{tier.desc}}</text>
        </view>
      </view>

    </view>
        <!-- 套餐限制说明 -->
    <view class="section" wx:if="{{model.planType && model.desc}}">
      <text class="section-title">📋 套餐说明</text>
      <text class="section-text">{{model.desc}}</text>
    </view>
    <view class="section">
      <text class="section-title">📊 技术参数</text>
      <view class="info-grid">
        <view class="info-item"><text class="info-label">上下文窗口</text><text class="info-value">{{model.contextWindow || '未知'}}</text></view>
        <view class="info-item" wx:if="{{model.maxOutput}}"><text class="info-label">最大输出</text><text class="info-value">{{model.maxOutput}}</text></view>
        <view class="info-item"><text class="info-label">模型类型</text><text class="info-value">{{model.modelType || '通用'}}</text></view>
        <view class="info-item" wx:if="{{model.capabilities}}"><text class="info-label">支持能力</text><text class="info-value">{{model.capabilities}}</text></view>
      </view>
    </view>
    <view class="section">
      <text class="section-title">🔗 价格来源</text>
      <view class="source-links">
        <text class="source-link" wx:for="{{model.sources}}" wx:key="*this" bindtap="onCopySource" data-url="{{item}}">{{item}}</text>
      </view>
    </view>
  </view>
</view>
