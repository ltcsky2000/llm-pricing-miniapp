.detail-card{padding:30rpx}
.model-header{text-align:center;padding:40rpx 0 30rpx;border-bottom:1rpx solid rgba(255,255,255,0.06);margin-bottom:30rpx}
.provider-tag{display:inline-block;font-size:22rpx;color:#fff;padding:6rpx 20rpx;border-radius:8rpx;margin-bottom:16rpx}
.header-name{font-size:44rpx;font-weight:700;color:#fff;margin-bottom:10rpx}.header-desc{font-size:26rpx;color:#888}.header-tag{margin-top:10rpx}.model-tag-detail{font-size:24rpx;color:#7eb8ff;background:rgba(100,149,237,0.12);padding:4rpx 16rpx;border-radius:10rpx}
.section{margin-bottom:36rpx}.section-title{font-size:30rpx;font-weight:600;color:#7eb8ff;display:block;margin-bottom:20rpx}
.price-table{background:rgba(255,255,255,0.03);border-radius:16rpx;overflow:hidden}
.price-row-detail{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;border-bottom:1rpx solid rgba(255,255,255,0.04)}
.price-row-detail:last-child{border-bottom:none}.price-type{font-size:28rpx;color:#ccc}.price-num{font-size:32rpx;font-weight:600;color:#ffd700}.price-num.small{font-size:26rpx;color:#aaa;font-weight:400}
.info-grid{display:flex;flex-wrap:wrap;gap:20rpx}.info-item{flex:1;min-width:260rpx;background:rgba(255,255,255,0.03);border-radius:12rpx;padding:20rpx}
.info-label{font-size:22rpx;color:#888;display:block;margin-bottom:6rpx}.info-value{font-size:28rpx;color:#e0e0e0}
.source-links{display:flex;flex-direction:column;gap:12rpx}.source-link{font-size:24rpx;color:#7eb8ff;text-decoration:underline;word-break:break-all}

/* 订阅套餐详情 */
.detail-tiers{display:flex;flex-direction:column;gap:16rpx}
.detail-tier{background:rgba(255,255,255,.03);border-radius:14rpx;padding:24rpx;border:1rpx solid rgba(255,255,255,.06)}
.detail-tier.featured{border-color:rgba(66,133,244,.25);background:rgba(66,133,244,.06)}
.detail-tier-header{display:flex;align-items:center;gap:12rpx;margin-bottom:10rpx}
.detail-tier-name{font-size:30rpx;font-weight:700;color:#e0e0e0}
.detail-tier-badge{font-size:20rpx;color:#fff;background:linear-gradient(135deg,#4285F4,#1a73e8);padding:2rpx 12rpx;border-radius:8rpx}
.detail-tier-price{font-size:36rpx;font-weight:800;color:#ffd700;display:block;margin-bottom:6rpx}
.detail-tier-period{font-size:22rpx;color:#999;font-weight:400}
.detail-tier-desc{font-size:24rpx;color:#888}
.detail-tags{display:flex;gap:10rpx;flex-wrap:wrap;margin-top:16rpx}
.detail-tag{font-size:22rpx;color:#7eb8ff;background:rgba(100,149,237,.12);padding:4rpx 14rpx;border-radius:12rpx}
.section-text{font-size:26rpx;color:#aaa;line-height:1.6;padding:0 4rpx}
