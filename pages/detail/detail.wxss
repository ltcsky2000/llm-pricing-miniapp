.detail-card{padding:30rpx}
.model-header{text-align:center;padding:40rpx 0 30rpx;border-bottom:1rpx solid rgba(255,255,255,0.06);margin-bottom:30rpx}
.provider-tag{display:inline-block;font-size:22rpx;color:#fff;padding:6rpx 20rpx;border-radius:8rpx;margin-bottom:16rpx}
.header-name{font-size:44rpx;font-weight:700;color:#fff;margin-bottom:10rpx}.header-desc{font-size:26rpx;color:#888}
.section{margin-bottom:36rpx}.section-title{font-size:30rpx;font-weight:600;color:#7eb8ff;display:block;margin-bottom:20rpx}
.price-table{background:rgba(255,255,255,0.03);border-radius:16rpx;overflow:hidden}
.price-row-detail{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;border-bottom:1rpx solid rgba(255,255,255,0.04)}
.price-row-detail:last-child{border-bottom:none}.price-type{font-size:28rpx;color:#ccc}.price-num{font-size:32rpx;font-weight:600;color:#ffd700}.price-num.small{font-size:26rpx;color:#aaa;font-weight:400}
.info-grid{display:flex;flex-wrap:wrap;gap:20rpx}.info-item{flex:1;min-width:260rpx;background:rgba(255,255,255,0.03);border-radius:12rpx;padding:20rpx}
.info-label{font-size:22rpx;color:#888;display:block;margin-bottom:6rpx}.info-value{font-size:28rpx;color:#e0e0e0}
.source-links{display:flex;flex-direction:column;gap:12rpx}.source-link{font-size:24rpx;color:#7eb8ff;text-decoration:underline;word-break:break-all}
